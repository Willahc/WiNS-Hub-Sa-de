# WiNS Hub Saude - Variaveis de ambiente (TEMPLATE)
# Copie para .env.saude e preencha com as credenciais reais.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=wins_hub_saude
DB_USER=wins_saude
DB_PASS=CHANGE_ME
DATABASE_URL=postgresql://wins_saude:CHANGE_ME@localhost:5432/wins_hub_saude

# Superusuario - usado apenas para DDL (ALTER TABLE / CREATE VIEW / GRANT),
# pois as tabelas pertencem ao usuario 'postgres'.
SUPERUSER_URL=postgresql://postgres:CHANGE_ME@localhost:5432/wins_hub_saude

# Token de compartilhamento RFB (WebDAV) usado por wins_hub_saude_qsa_bulk.py
RFB_SHARE_TOKEN=CHANGE_ME
RFB_YM=2026-06
